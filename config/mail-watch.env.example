# Telegram bot token from BotFather.
TELEGRAM_BOT_TOKEN=123456789:replace-with-your-token

# Target chat id. For private chats this is often a positive integer; groups
# and channels commonly use negative ids.
TELEGRAM_CHAT_ID=123456789

# Optional Telegram Bot API base URL. Leave this as-is unless you use a proxy
# or a self-hosted compatible endpoint.
TELEGRAM_API_BASE=https://api.telegram.org

# Optional message settings.
TELEGRAM_MESSAGE_PREFIX=New mail
TELEGRAM_DISABLE_WEB_PAGE_PREVIEW=true
TELEGRAM_DISABLE_NOTIFICATION=false
TELEGRAM_PROTECT_CONTENT=false
TELEGRAM_TIMEOUT_SECONDS=15

# Optional topic id for Telegram forum topics.
#TELEGRAM_MESSAGE_THREAD_ID=

# Optional label shown in the notification. You can also set this per Mirador
# hook command with: MAIL_WATCH_ACCOUNT=personal scripts/send-telegram-mail.sh
#MAIL_WATCH_ACCOUNT=personal

# Dry-run mode prints the message instead of sending it. Useful for local tests.
MAIL_WATCH_DRY_RUN=false
